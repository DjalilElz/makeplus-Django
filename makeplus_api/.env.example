# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
# Use Supabase database (True) or local SQLite (False)
USE_SUPABASE=False

# Supabase Database Configuration (Session Pooler for Render - IPv4 compatible)
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=your-supabase-user
SUPABASE_DB_PASSWORD=your-supabase-password
SUPABASE_DB_HOST=your-supabase-host
SUPABASE_DB_PORT=6543

# Supabase API Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

ALLOWED_HOSTS=localhost,127.0.0.1,*.ngrok.io

# Brevo (Sendinblue) Email Configuration
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-smtp-user@smtp-brevo.com
EMAIL_HOST_PASSWORD=your-brevo-api-key-here
DEFAULT_FROM_EMAIL=your-email@example.com
SITE_URL=http://127.0.0.1:8000
